MLFLOW_TRACKING_URI=http://localhost:5000

OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini

# LLM provider: "openai" (default) or "litellm"
# With litellm, use provider/model format (e.g. anthropic/claude-3-haiku-20240307)
LLM_PROVIDER=openai

BATCH_SIZE=50
CONCURRENCY=10

POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5462

MLFLOW_BUCKET=mlflow-artifacts
MLFLOW_PORT=5000

AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
MLFLOW_S3_ENDPOINT_URL=http://localhost:9000

MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

DUCKDB_PATH=data/camel.duckdb
RAW_PARQUET_PATH=data/bronze/train.parquet
SILVER_PARQUET_PATH=data/silver/train_sample.parquet
SAMPLE_FRACTION=0.1
SAMPLE_SEED=42
PASS_AT_K=3
PASS_AT_K_TEMPERATURE=0.7
INFERENCE_CACHE_DIR=data/cache/inferences
PROMPT_TEMPLATE_PATH=prompts/system_prompt.j2
RESULTS_DIR=results

OLLAMA_API_BASE=http://localhost:11434
 